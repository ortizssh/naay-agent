{% comment %}
  Naay AI Chat Widget Block
  This block embeds the Naay AI chat widget into any Shopify theme
{% endcomment %}

<!-- Naay Chat Widget Container -->
<div id="naay-chat-container" data-shop="{{ shop.permanent_domain }}">
  <!-- Chat widget will be created here by the JavaScript -->
</div>

<script>
  // HARDCODED Naay Widget Configuration - No customization allowed
  window.NaayConfig = {
    shopDomain: '{{ shop.permanent_domain }}',
    apiEndpoint: 'https://naay-agent-app1763504937.azurewebsites.net',
    position: 'bottom-right',
    primaryColor: '#8B5A3C',
    greeting: '¡Hola! 🌿 Soy tu asistente de Naay. ¿Cómo puedo ayudarte a encontrar el cuidado perfecto para tu piel?',
    placeholder: 'Escribe tu mensaje...',
    theme: 'light',
    avatar: '🌿',
    language: '{{ request.locale.iso_code | default: "es" }}',
    enabled: true,
    
    // Shopify-specific context
    context: {
      customerLoggedIn: {% if customer %}true{% else %}false{% endif %},
      customerId: {% if customer %}'{{ customer.id }}'{% else %}null{% endif %},
      customerEmail: {% if customer %}'{{ customer.email | escape }}'{% else %}null{% endif %},
      currency: '{{ cart.currency.iso_code }}',
      shopName: '{{ shop.name | escape }}',
      cartToken: {{ cart.token | json }},
      cartId: {% if cart.id %}'gid://shopify/Cart/{{ cart.id }}'{% else %}null{% endif %},
      pageType: '{{ request.page_type }}',
      productId: {% if product %}'gid://shopify/Product/{{ product.id }}'{% else %}null{% endif %},
      collectionId: {% if collection %}'gid://shopify/Collection/{{ collection.id }}'{% else %}null{% endif %}
    }
  };
</script>

<!-- Load the Naay Widget -->
<script>
  (function() {
    console.log('🌿 Naay Chat: Initializing widget v3.0-LUXURY...');
    
    // Don't load in admin preview or checkout
    if (window.location.hostname.includes('admin') || window.location.pathname.includes('checkout')) {
      console.log('Naay Chat: Skipping load in admin/checkout');
      return;
    }
    
    // Load the official Naay widget script
    var script = document.createElement('script');
    script.src = 'https://naay-agent-app1763504937.azurewebsites.net/static/naay-widget.js?v=N8N_WEBHOOK_002&id=' + (Math.random().toString(36) + Math.random().toString(36)).substr(2, 20) + '&t=' + Date.now() + '&force=true';
    script.async = true;
    
    script.onload = function() {
      console.log('✅ Naay Chat: Widget script loaded successfully');
      if (window.NaayWidget && window.NaayConfig) {
        try {
          // Initialize the official Naay widget
          new window.NaayWidget(window.NaayConfig);
          console.log('🎉 Naay Chat: Widget initialized successfully with promotional message');
        } catch (error) {
          console.error('❌ Failed to initialize Naay Widget:', error);
        }
      } else {
        console.error('❌ NaayWidget or NaayConfig not available');
      }
    };
    
    script.onerror = function() {
      console.error('❌ Failed to load Naay Widget script from Azure server');
    };
    
    document.head.appendChild(script);
  })();
</script>

<style>
  /* Ensure Naay widget doesn't interfere with theme */
  #naay-chat-container {
    position: relative;
    z-index: 9999;
  }
  
  /* Hide widget in admin areas */
  .shopify-section-header #naay-chat-container,
  .admin #naay-chat-container {
    display: none !important;
  }
</style>

{% schema %}
{
  "name": "Naay AI Chat v3.0-LUXURY",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "This widget uses a locked Naay brand configuration. No customization options are available to ensure brand consistency."
    },
    {
      "type": "header",
      "content": "Widget Status"
    },
    {
      "type": "paragraph",
      "content": "✅ Widget is always enabled with Naay's official design and promotional message: '¿Necesitas ayuda para tu compra? ¡Habla aquí!'"
    }
  ]
}
{% endschema %}