{% comment %}
  Kova AI Chat Widget - App Block
  This is the official Kova AI chat widget for Shopify stores
{% endcomment %}

<div 
  id="naay-chat-widget-{{ block.id }}" 
  class="naay-chat-widget-container"
  data-shop="{{ shop.permanent_domain }}"
  data-block-id="{{ block.id }}"
  {{ block.shopify_attributes }}
>
  <!-- Widget will be rendered here -->
</div>

<script>
  // Kova Widget Configuration
  window.NaayConfig = window.NaayConfig || {};
  window.NaayConfig = {
    shopDomain: '{{ shop.permanent_domain }}',
    apiEndpoint: 'https://naay-agent-app1763504937.azurewebsites.net',
    position: 'bottom-right',
    primaryColor: '#a59457',
    greeting: '¿Necesitas ayuda para tu compra? ¡Habla aquí!',
    placeholder: 'Pregúntanos sobre tu compra...',
    theme: 'light',
    avatar: '🌿',
    language: '{{ request.locale.iso_code | default: "es" }}',
    enabled: true,
    blockId: '{{ block.id }}',
    
    // Shopify context
    context: {
      customerLoggedIn: {% if customer %}true{% else %}false{% endif %},
      customerId: {% if customer %}'{{ customer.id }}'{% else %}null{% endif %},
      customerEmail: {% if customer %}'{{ customer.email | escape }}'{% else %}null{% endif %},
      currency: '{{ cart.currency.iso_code }}',
      shopName: '{{ shop.name | escape }}',
      cartToken: {{ cart.token | json }},
      cartId: {% if cart.id %}'gid://shopify/Cart/{{ cart.id }}'{% else %}null{% endif %},
      pageType: '{{ request.page_type }}',
      productId: {% if product %}'gid://shopify/Product/{{ product.id }}'{% else %}null{% endif %},
      collectionId: {% if collection %}'gid://shopify/Collection/{{ collection.id }}'{% else %}null{% endif %}
    }
  };

  // Load widget script only once per page
  if (!window.naayWidgetLoaded) {
    window.naayWidgetLoaded = true;
    
    console.log('🌿 Kova Chat: Loading widget for block {{ block.id }}');
    
    var script = document.createElement('script');
    script.src = 'https://naay-agent-app1763504937.azurewebsites.net/widget/naay-widget.js?v=' + Date.now();
    script.async = true;
    script.crossOrigin = 'anonymous';
    script.onload = function() {
      console.log('✅ Kova Chat: Widget loaded successfully');
      try {
        // Only initialize if no widget instance exists
        if (window.NaayWidget && window.NaayConfig && !window.naayWidgetInstance) {
          window.naayWidgetInstance = new window.NaayWidget(window.NaayConfig);
          console.log('✅ Kova Widget instance created');
        } else if (window.naayWidgetInstance) {
          console.log('⚠️ Kova Widget instance already exists, skipping creation');
        } else {
          console.warn('⚠️ NaayWidget or NaayConfig not available after script load');
        }
      } catch (error) {
        console.error('❌ Error initializing Kova Widget:', error);
      }
    };
    script.onerror = function(error) {
      console.error('❌ Failed to load Kova Widget script:', error);
    };
    document.head.appendChild(script);
  } else if (window.NaayWidget && window.NaayConfig && !window.naayWidgetInstance) {
    // Script already loaded, but no instance created yet
    console.log('🔄 Kova Chat: Script already loaded, creating widget instance');
    try {
      window.naayWidgetInstance = new window.NaayWidget(window.NaayConfig);
      console.log('✅ Kova Widget instance created');
    } catch (error) {
      console.error('❌ Error creating Kova Widget instance:', error);
    }
  } else if (window.naayWidgetInstance) {
    console.log('✅ Kova Widget already running, no action needed');
  }
</script>

<style>
  .naay-chat-widget-container {
    position: relative;
    z-index: 9999;
  }
  
  /* Hide in admin preview */
  .shopify-section-header .naay-chat-widget-container {
    display: none !important;
  }
</style>

{% schema %}
{
  "name": "Kova AI Chat Widget",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Kova AI Chat Widget"
    },
    {
      "type": "paragraph",
      "content": "El asistente de IA para tu tienda Shopify. Ayuda a tus clientes a encontrar productos y responde sus preguntas automáticamente."
    },
    {
      "type": "paragraph",
      "content": "✅ Widget configurado y activo"
    }
  ]
}
{% endschema %}