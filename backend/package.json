{
  "name": "@naay-agent/backend",
  "version": "1.0.0",
  "description": "Backend API para Naay Agent - Shopify + Supabase",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:safe",
    "build:safe": "npm run build:compile && npm run build:alias && npm run build:assets",
    "build:compile": "tsc -p tsconfig.deployment.json",
    "build:alias": "tsc-alias -p tsconfig.deployment.json || echo 'tsc-alias skipped'",
    "build:assets": "cp -r public dist/ 2>/dev/null || echo 'No public directory to copy'",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@shopify/admin-api-client": "^1.0.0",
    "@shopify/storefront-api-client": "^1.0.0",
    "@supabase/supabase-js": "^2.38.0",
    "axios": "^1.5.0",
    "bullmq": "^4.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.0.0",
    "ioredis": "^5.3.2",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "openai": "^4.12.0",
    "pdf-parse": "^1.1.1",
    "stripe": "^20.3.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.5.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "jest": "^29.6.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.1.1",
    "tsx": "^3.12.7"
  }
}
